# -------------------------------------------------------
# Cellular Maze Backend -- Environment Variables
# -------------------------------------------------------

# Application
PROJECT_NAME="Cellular Maze API"
VERSION="1.0.0"

# External Services
ML_MODEL_URL="http://localhost:8001"
OSRM_URL="http://router.project-osrm.org"

# MongoDB (Motor async driver)
MONGO_URI="mongodb://localhost:27017"
DB_NAME="cellularmaze"

# Timeouts (seconds)
ML_TIMEOUT_S=5.0
OSRM_TIMEOUT_S=10.0

# Signal Cache
SIGNAL_CACHE_TTL_S=300
SIGNAL_CACHE_MAX_SIZE=10000
